# DashScope visual-language model (required)
DASHSCOPE_API_KEY=
# Optional overrides
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_VLM=qwen3-vl-plus

# Text LLM endpoint (required)
API_ENDPOINT_LLM=
# Optional API key and model override
API_KEY_LLM=
MODEL_LLM=gpt-4o-mini

# RAG embedding API (optional)
# If EMBEDDING_API_KEY and EMBEDDING_MODEL are set, RAG will use third-party
# embedding API through Chroma OpenAIEmbeddingFunction.
# Otherwise it falls back to Chroma default embedding.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

ENABLE_LLM_ISSUE_MERGE=true